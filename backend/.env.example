# Application
APP_ENV=development
APP_URL=http://localhost:8000

# Database
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=drivewise
DB_USERNAME=drivewise
DB_PASSWORD=secret

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=86400

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AI (Groq - free tier)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama3-8b-8192

# AI (Google Gemini - alternative free tier)
GEMINI_API_KEY=your-gemini-api-key

# WhatsApp (Chatvik)
CHATVIK_API_KEY=your-chatvik-api-key
CHATVIK_API_URL=https://api.chatvik.com/v1/send

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:4200
